{
  "name": "parvagas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "server": "node server/server.js",
    "server:dev": "NODE_ENV=development PORT=6001 NEXT_PUBLIC_API_URL=http://localhost:6001 CORS_ORIGIN=http://localhost:3000 node server/server.js",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --test server/tests/**/*.test.js",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "readiness:production": "NODE_ENV=production node server/scripts/productionReadiness.mjs",
    "readiness:production:services": "NODE_ENV=production node server/scripts/productionReadiness.mjs --check-services",
    "db:bootstrap": "node server/migrations/bootstrap.mjs",
    "db:seed:real": "node server/scripts/seedRealData.mjs",
    "db:seed:dummy": "node server/scripts/seedDummyData.mjs",
    "reindex:jobs": "node server/scripts/reindexPublicJobs.js",
    "db:migration:generate": "node server/scripts/generateMigrationStub.js"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@material-tailwind/react": "^2.1.9",
    "@sentry/node": "^10.51.0",
    "@supabase/supabase-js": "^2.50.2",
    "@tanstack/react-query": "^5.100.6",
    "@vercel/analytics": "^1.1.3",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "gridfs-stream": "^1.1.1",
    "helmet": "^7.1.0",
    "heroicons": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "meilisearch": "^0.52.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.35",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^1.1.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.1.1",
    "pg": "^8.20.0",
    "postcss": "^8",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
