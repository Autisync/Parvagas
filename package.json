{
  "name": "parvagas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 NEXT_IMAGE_UNOPTIMIZED=1 next dev --hostname 0.0.0.0 --port 3000",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend-python celery-worker",
    "db:migrate": "docker compose exec backend-python alembic upgrade head",
    "db:migration:generate": "docker compose exec backend-python alembic revision --autogenerate -m auto_migration",
    "db:copy:old-to-new": "docker compose --profile migration run --rm db-migrator"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@material-tailwind/react": "^2.1.9",
    "@sentry/node": "^10.51.0",
    "@sentry/react": "^10.60.0",
    "@supabase/supabase-js": "^2.50.2",
    "@tanstack/react-query": "^5.100.6",
    "@vercel/analytics": "^1.1.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "gridfs-stream": "^1.1.1",
    "helmet": "^7.1.0",
    "heroicons": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "meilisearch": "^0.52.0",
    "morgan": "^1.10.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autocannon": "^2.0.1",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
