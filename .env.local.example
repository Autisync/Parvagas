COMPOSE_PROJECT_NAME=parvagas-local
APP_ENV=development

POSTGRES_USER=parvagas
POSTGRES_PASSWORD=devpass
POSTGRES_DB=parvagas_local
CV_BUILDER_DB=parvagas_cv_builder_local
DATABASE_URL=postgresql+psycopg://parvagas:devpass@postgres:5432/parvagas_local
CV_BUILDER_DATABASE_URL=postgresql://parvagas:devpass@postgres:5432/parvagas_cv_builder_local

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CV_BUILDER_S3_BUCKET=reactive-resume-local
S3_BUCKET=cvs-local

JWT_SECRET=dev-jwt-secret
RESUME_BUILDER_SECRET=dev-cv-builder-secret
CV_BUILDER_SERVER_SECRET=dev-cv-builder-secret
CV_BUILDER_ENCRYPTION_SECRET=dev-cv-builder-encryption-secret-minimum-32-chars

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
RESUME_BUILDER_URL=http://localhost:3050
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RESUME_BUILDER_URL=http://localhost:3050

CV_BUILDER_DISABLE_SIGNUPS=false
CV_BUILDER_DISABLE_EMAIL_AUTH=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
