COMPOSE_PROJECT_NAME=parvagas-dev
APP_ENV=development

# Fully expanded URLs only (no nested interpolation)
POSTGRES_USER=parvagas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=parvagas_dev
CV_BUILDER_DB=parvagas_cv_builder_dev
DATABASE_URL=postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas_dev
CV_BUILDER_DATABASE_URL=postgresql://parvagas:CHANGE_ME@postgres:5432/parvagas_cv_builder_dev

MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
CV_BUILDER_S3_BUCKET=reactive-resume-dev
S3_BUCKET=cvs-dev

JWT_SECRET=CHANGE_ME
RESUME_BUILDER_SECRET=CHANGE_ME
CV_BUILDER_ENCRYPTION_SECRET=CHANGE_ME_MIN_32_CHARS
CV_BUILDER_DISABLE_SIGNUPS=false
CV_BUILDER_DISABLE_EMAIL_AUTH=false

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dev@parvagas.pt
SMTP_SECURE=false

TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
API_HOST=api-dev.parvagas.pt
CV_HOST=cv-dev.parvagas.pt
STORAGE_HOST=storage-dev.parvagas.pt

BACKEND_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:dev
WORKER_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:dev
CV_BUILDER_IMAGE=ghcr.io/heliotheanalyst/parvagas-cv-builder:dev
CV_BUILDER_MIGRATE_IMAGE=ghcr.io/heliotheanalyst/parvagas-cv-builder-migrate:dev
