name: parvagas-prod
services:
  backend:
    depends_on:
      postgres:
        condition: service_healthy
        required: true
      redis:
        condition: service_healthy
        required: true
    environment:
      ACCESS_TOKEN_EXPIRE_MINUTES: "60"
      ADMIN_SIGNUP_KEY: CHANGE_ME
      APP_ENV: production
      BACKEND_URL: https://api.parvagas.pt
      CELERY_BROKER_URL: redis://redis:6379/1
      CELERY_RESULT_BACKEND: redis://redis:6379/2
      CORS_ORIGIN: https://parvagas.pt,https://api.parvagas.pt,https://cv.parvagas.pt
      DATABASE_URL: postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas
      EMAIL_PROVIDER: smtp
      FRONTEND_URL: https://parvagas.pt
      JWT_ALGORITHM: HS256
      JWT_SECRET: CHANGE_ME
      MODERATOR_SIGNUP_KEY: ""
      REDIS_URL: redis://redis:6379/0
      RESUME_BUILDER_SECRET: CHANGE_ME
      RESUME_BUILDER_URL: https://cv.parvagas.pt
      S3_ACCESS_KEY: minioadmin
      S3_BUCKET: cvs
      S3_ENDPOINT_URL: https://storage.parvagas.pt
      S3_REGION: us-east-1
      S3_SECRET_KEY: minioadmin
      SMTP_FROM: ""
      SMTP_HOST: ""
      SMTP_PASS: ""
      SMTP_PORT: "587"
      SMTP_SECURE: "true"
      SMTP_USER: ""
      SUPER_ADMIN_EMAIL: admin@parvagas.pt
      TRUSTED_HOSTS: '*'
    healthcheck:
      test:
        - CMD
        - python
        - -c
        - import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 1m0s
    image: ghcr.io/heliotheanalyst/parvagas-backend:prod
    labels:
      traefik.docker.network: proxy
      traefik.enable: "true"
      traefik.http.routers.parvagas-prod-api.entrypoints: websecure
      traefik.http.routers.parvagas-prod-api.rule: Host(`api.parvagas.pt`)
      traefik.http.routers.parvagas-prod-api.tls: "true"
      traefik.http.routers.parvagas-prod-api.tls.certresolver: letsencrypt
      traefik.http.services.parvagas-prod-api.loadbalancer.server.port: "8000"
    networks:
      default: {}
      traefik:
        aliases:
          - parvagas-prod-api
    pull_policy: always
    restart: unless-stopped
    user: "0:0"
    volumes:
      - type: volume
        source: parvagas_prod_backend_media
        target: /app/uploads
        volume: {}
      - type: volume
        source: parvagas_prod_backend_static
        target: /app/logs
        volume: {}
  cv-builder:
    build:
      context: C:\Users\pizt1\Documents\Business\Parvagas\reactive-resume
      dockerfile: Dockerfile
      target: runtime
    depends_on:
      cv-builder-bucket-init:
        condition: service_completed_successfully
        required: true
      cv-builder-db-init:
        condition: service_completed_successfully
        required: true
      minio-init:
        condition: service_completed_successfully
        required: true
      postgres:
        condition: service_healthy
        required: true
      redis:
        condition: service_healthy
        required: true
    environment:
      APP_URL: https://cv.parvagas.pt
      AUTH_SECRET: CHANGE_ME
      DATABASE_URL: postgresql://parvagas:CHANGE_ME@postgres:5432/parvagas_cv_builder
      ENCRYPTION_SECRET: CHANGE_ME_MIN_32_CHARS
      FLAG_DISABLE_API_RATE_LIMIT: "false"
      FLAG_DISABLE_EMAIL_AUTH: "true"
      FLAG_DISABLE_SIGNUPS: "true"
      FLAG_SHOW_SPONSORS: "false"
      NODE_ENV: production
      OAUTH_CLIENT_ID: REQUIRED_IF_SIGNUPS_DISABLED
      OAUTH_CLIENT_SECRET: REQUIRED_IF_SIGNUPS_DISABLED
      OAUTH_DISCOVERY_URL: REQUIRED_IF_SIGNUPS_DISABLED
      OAUTH_PROVIDER_NAME: Parvagas
      OAUTH_SCOPES: openid profile email
      PORT: "3000"
      REDIS_URL: redis://redis:6379
      S3_ACCESS_KEY_ID: minioadmin
      S3_BUCKET: reactive-resume
      S3_ENDPOINT: http://minio:9000
      S3_FORCE_PATH_STYLE: "true"
      S3_REGION: us-east-1
      S3_SECRET_ACCESS_KEY: minioadmin
      SMTP_FROM: Parvagas CV Builder <suporte@parvagas.pt>
      SMTP_HOST: ""
      SMTP_PASS: ""
      SMTP_PORT: "587"
      SMTP_SECURE: "true"
      SMTP_USER: ""
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - fetch('http://127.0.0.1:3000/api/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 1m0s
    labels:
      traefik.docker.network: proxy
      traefik.enable: "true"
      traefik.http.routers.parvagas-prod-cv.entrypoints: websecure
      traefik.http.routers.parvagas-prod-cv.rule: Host(`cv.parvagas.pt`)
      traefik.http.routers.parvagas-prod-cv.tls: "true"
      traefik.http.routers.parvagas-prod-cv.tls.certresolver: letsencrypt
      traefik.http.services.parvagas-prod-cv.loadbalancer.server.port: "3000"
    networks:
      default: {}
      traefik:
        aliases:
          - parvagas-prod-cv
    restart: unless-stopped
    volumes:
      - type: volume
        source: cv_builder_data
        target: /app/data
        volume: {}
  cv-builder-bucket-init:
    depends_on:
      minio:
        condition: service_started
        required: true
    entrypoint:
      - /bin/sh
      - -c
      - until mc alias set local http://minio:9000 $$MINIO_ROOT_USER $$MINIO_ROOT_PASSWORD; do echo 'Waiting for MinIO...'; sleep 3; done; mc mb --ignore-existing local/$$CV_BUILDER_S3_BUCKET; mc anonymous set none local/$$CV_BUILDER_S3_BUCKET; echo 'CV Builder bucket ready';
    environment:
      CV_BUILDER_S3_BUCKET: reactive-resume
      MINIO_ROOT_PASSWORD: minioadmin
      MINIO_ROOT_USER: minioadmin
    image: quay.io/minio/mc:latest
    networks:
      default: null
    restart: "no"
  cv-builder-db-init:
    depends_on:
      postgres:
        condition: service_healthy
        required: true
    entrypoint:
      - /bin/sh
      - -c
      - " if psql -tAc \"SELECT 1 FROM pg_database WHERE datname='$$CV_BUILDER_DB'\" | grep -q 1; then\n  echo 'CV Builder database already exists';\nelse\n  createdb \"$$CV_BUILDER_DB\";\n  echo 'CV Builder database created';\nfi "
    environment:
      CV_BUILDER_DB: parvagas_cv_builder
      PGHOST: postgres
      PGPASSWORD: devpass
      PGPORT: "5432"
      PGUSER: parvagas
    image: postgres:16-alpine
    networks:
      default: null
    restart: "no"
  minio:
    command:
      - server
      - /data
    environment:
      MINIO_ROOT_PASSWORD: minioadmin
      MINIO_ROOT_USER: minioadmin
    image: minio/minio:RELEASE.2025-01-20T14-49-07Z
    labels:
      traefik.docker.network: proxy
      traefik.enable: "true"
      traefik.http.routers.parvagas-prod-storage.entrypoints: websecure
      traefik.http.routers.parvagas-prod-storage.rule: Host(`storage.parvagas.pt`)
      traefik.http.routers.parvagas-prod-storage.tls: "true"
      traefik.http.routers.parvagas-prod-storage.tls.certresolver: letsencrypt
      traefik.http.services.parvagas-prod-storage.loadbalancer.server.port: "9000"
    networks:
      default: {}
      traefik:
        aliases:
          - parvagas-prod-storage
    restart: unless-stopped
    volumes:
      - type: volume
        source: parvagas_prod_minio_data
        target: /data
        volume: {}
  minio-init:
    depends_on:
      minio:
        condition: service_started
        required: true
    entrypoint:
      - /bin/sh
      - -c
      - " until mc alias set local http://minio:9000 $$MINIO_ROOT_USER $$MINIO_ROOT_PASSWORD; do\n  sleep 3;\ndone; mc mb --ignore-existing local/$$BACKEND_BUCKET; mc anonymous set none local/$$BACKEND_BUCKET; echo 'backend bucket ready'; "
    environment:
      BACKEND_BUCKET: cvs
      MINIO_ROOT_PASSWORD: minioadmin
      MINIO_ROOT_USER: minioadmin
    image: minio/mc:RELEASE.2025-01-17T23-25-50Z
    networks:
      default: null
    restart: "no"
  postgres:
    environment:
      POSTGRES_DB: parvagas
      POSTGRES_PASSWORD: devpass
      POSTGRES_USER: parvagas
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U $${POSTGRES_USER:-parvagas} -d $${POSTGRES_DB:-parvagas}
      timeout: 5s
      interval: 10s
      retries: 10
      start_period: 20s
    image: postgres:16-alpine
    networks:
      default: null
    restart: unless-stopped
    volumes:
      - type: volume
        source: parvagas_prod_postgres_data
        target: /var/lib/postgresql/data
        volume: {}
  redis:
    healthcheck:
      test:
        - CMD
        - redis-cli
        - ping
      timeout: 5s
      interval: 10s
      retries: 10
    image: redis:7-alpine
    networks:
      default: null
    restart: unless-stopped
    volumes:
      - type: volume
        source: parvagas_prod_redis_data
        target: /data
        volume: {}
  scheduler:
    command:
      - celery
      - -A
      - app.workers.celery_app
      - beat
      - --loglevel=info
    depends_on:
      postgres:
        condition: service_healthy
        required: true
      redis:
        condition: service_healthy
        required: true
    environment:
      ACCESS_TOKEN_EXPIRE_MINUTES: "60"
      ADMIN_SIGNUP_KEY: CHANGE_ME
      APP_ENV: production
      BACKEND_URL: https://api.parvagas.pt
      CELERY_BROKER_URL: redis://redis:6379/1
      CELERY_RESULT_BACKEND: redis://redis:6379/2
      CORS_ORIGIN: https://parvagas.pt,https://api.parvagas.pt,https://cv.parvagas.pt
      DATABASE_URL: postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas
      EMAIL_PROVIDER: smtp
      FRONTEND_URL: https://parvagas.pt
      JWT_ALGORITHM: HS256
      JWT_SECRET: CHANGE_ME
      MODERATOR_SIGNUP_KEY: ""
      REDIS_URL: redis://redis:6379/0
      RESUME_BUILDER_SECRET: CHANGE_ME
      RESUME_BUILDER_URL: https://cv.parvagas.pt
      S3_ACCESS_KEY: minioadmin
      S3_BUCKET: cvs
      S3_ENDPOINT_URL: https://storage.parvagas.pt
      S3_REGION: us-east-1
      S3_SECRET_KEY: minioadmin
      SMTP_FROM: ""
      SMTP_HOST: ""
      SMTP_PASS: ""
      SMTP_PORT: "587"
      SMTP_SECURE: "true"
      SMTP_USER: ""
      SUPER_ADMIN_EMAIL: admin@parvagas.pt
      TRUSTED_HOSTS: '*'
    image: ghcr.io/heliotheanalyst/parvagas-backend:prod
    networks:
      default: null
    pull_policy: always
    restart: unless-stopped
    user: "0:0"
  worker:
    command:
      - celery
      - -A
      - app.workers.celery_app
      - worker
      - --loglevel=info
      - --concurrency=4
      - --prefetch-multiplier=1
      - -Q
      - default,emails,parsing,cleanup,scraping
    depends_on:
      postgres:
        condition: service_healthy
        required: true
      redis:
        condition: service_healthy
        required: true
    environment:
      ACCESS_TOKEN_EXPIRE_MINUTES: "60"
      ADMIN_SIGNUP_KEY: CHANGE_ME
      APP_ENV: production
      BACKEND_URL: https://api.parvagas.pt
      CELERY_BROKER_URL: redis://redis:6379/1
      CELERY_RESULT_BACKEND: redis://redis:6379/2
      CORS_ORIGIN: https://parvagas.pt,https://api.parvagas.pt,https://cv.parvagas.pt
      DATABASE_URL: postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas
      EMAIL_PROVIDER: smtp
      FRONTEND_URL: https://parvagas.pt
      JWT_ALGORITHM: HS256
      JWT_SECRET: CHANGE_ME
      MODERATOR_SIGNUP_KEY: ""
      REDIS_URL: redis://redis:6379/0
      RESUME_BUILDER_SECRET: CHANGE_ME
      RESUME_BUILDER_URL: https://cv.parvagas.pt
      S3_ACCESS_KEY: minioadmin
      S3_BUCKET: cvs
      S3_ENDPOINT_URL: https://storage.parvagas.pt
      S3_REGION: us-east-1
      S3_SECRET_KEY: minioadmin
      SMTP_FROM: ""
      SMTP_HOST: ""
      SMTP_PASS: ""
      SMTP_PORT: "587"
      SMTP_SECURE: "true"
      SMTP_USER: ""
      SUPER_ADMIN_EMAIL: admin@parvagas.pt
      TRUSTED_HOSTS: '*'
    healthcheck:
      test:
        - CMD-SHELL
        - celery -A app.workers.celery_app inspect ping -d celery@$$(hostname) || exit 1
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 1m0s
    image: ghcr.io/heliotheanalyst/parvagas-backend:prod
    networks:
      default: null
    pull_policy: always
    restart: unless-stopped
    user: "0:0"
    volumes:
      - type: volume
        source: parvagas_prod_backend_media
        target: /app/uploads
        volume: {}
      - type: volume
        source: parvagas_prod_backend_static
        target: /app/logs
        volume: {}
networks:
  default:
    name: parvagas-prod_internal
  traefik:
    name: proxy
    external: true
volumes:
  cv_builder_data:
    name: parvagas-prod_cv_builder_data
  parvagas_prod_backend_media:
    name: parvagas-prod_parvagas_prod_backend_media
  parvagas_prod_backend_static:
    name: parvagas-prod_parvagas_prod_backend_static
  parvagas_prod_minio_data:
    name: parvagas-prod_parvagas_prod_minio_data
  parvagas_prod_postgres_data:
    name: parvagas-prod_parvagas_prod_postgres_data
  parvagas_prod_redis_data:
    name: parvagas-prod_parvagas_prod_redis_data
x-backend-env:
  ACCESS_TOKEN_EXPIRE_MINUTES: "60"
  ADMIN_SIGNUP_KEY: CHANGE_ME
  APP_ENV: production
  BACKEND_URL: https://api.parvagas.pt
  CELERY_BROKER_URL: redis://redis:6379/1
  CELERY_RESULT_BACKEND: redis://redis:6379/2
  CORS_ORIGIN: https://parvagas.pt,https://api.parvagas.pt,https://cv.parvagas.pt
  DATABASE_URL: postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas
  EMAIL_PROVIDER: smtp
  FRONTEND_URL: https://parvagas.pt
  JWT_ALGORITHM: HS256
  JWT_SECRET: CHANGE_ME
  MODERATOR_SIGNUP_KEY: ""
  REDIS_URL: redis://redis:6379/0
  RESUME_BUILDER_SECRET: CHANGE_ME
  RESUME_BUILDER_URL: https://cv.parvagas.pt
  S3_ACCESS_KEY: minioadmin
  S3_BUCKET: cvs
  S3_ENDPOINT_URL: https://storage.parvagas.pt
  S3_REGION: us-east-1
  S3_SECRET_KEY: minioadmin
  SMTP_FROM: ""
  SMTP_HOST: ""
  SMTP_PASS: ""
  SMTP_PORT: "587"
  SMTP_SECURE: "true"
  SMTP_USER: ""
  SUPER_ADMIN_EMAIL: admin@parvagas.pt
  TRUSTED_HOSTS: '*'
x-cv-env:
  APP_URL: https://cv.parvagas.pt
  AUTH_SECRET: CHANGE_ME
  DATABASE_URL: postgresql://parvagas:CHANGE_ME@postgres:5432/parvagas_cv_builder
  ENCRYPTION_SECRET: CHANGE_ME_MIN_32_CHARS
  FLAG_DISABLE_API_RATE_LIMIT: "false"
  FLAG_DISABLE_EMAIL_AUTH: "true"
  FLAG_DISABLE_SIGNUPS: "true"
  FLAG_SHOW_SPONSORS: "false"
  NODE_ENV: production
  OAUTH_CLIENT_ID: REQUIRED_IF_SIGNUPS_DISABLED
  OAUTH_CLIENT_SECRET: REQUIRED_IF_SIGNUPS_DISABLED
  OAUTH_DISCOVERY_URL: REQUIRED_IF_SIGNUPS_DISABLED
  OAUTH_PROVIDER_NAME: Parvagas
  OAUTH_SCOPES: openid profile email
  PORT: "3000"
  REDIS_URL: redis://redis:6379
  S3_ACCESS_KEY_ID: minioadmin
  S3_BUCKET: reactive-resume
  S3_ENDPOINT: http://minio:9000
  S3_FORCE_PATH_STYLE: "true"
  S3_REGION: us-east-1
  S3_SECRET_ACCESS_KEY: minioadmin
  SMTP_FROM: Parvagas CV Builder <suporte@parvagas.pt>
  SMTP_HOST: ""
  SMTP_PASS: ""
  SMTP_PORT: "587"
  SMTP_SECURE: "true"
  SMTP_USER: ""
