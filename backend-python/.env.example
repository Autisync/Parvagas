# Example environment file for backend-python
# Copy to .env and update values

APP_ENV=development
PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://parvagas_user:change_me@postgres:5432/parvagas

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Auth provider
# local: validates tokens using JWT_SECRET/JWT_ALGORITHM
# auth0: validates bearer tokens against Auth0 JWKS
AUTH_PROVIDER=local
AUTH0_DOMAIN=dev-l6ezvm4bxffm0h0w.eu.auth0.com
AUTH0_AUDIENCE=https://dev-l6ezvm4bxffm0h0w.eu.auth0.com/api/v2/
AUTH0_ISSUER=https://dev-l6ezvm4bxffm0h0w.eu.auth0.com/
AUTH0_ALGORITHMS=RS256

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# SMTP
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-password
SMTP_FROM=Parvagas <noreply@example.com>

# File upload
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Optional AI-assisted CV parsing
# Providers: openai, openrouter, azure
CV_PARSER_AI_ENABLED=false
CV_PARSER_AI_PROVIDER=openai
CV_PARSER_AI_BASE_URL=https://api.openai.com/v1
CV_PARSER_AI_API_KEY=
CV_PARSER_AI_MODEL=gpt-4.1-mini
CV_PARSER_AI_TIMEOUT_SECONDS=30
CV_PARSER_AI_ORGANIZATION=
CV_PARSER_AI_PROJECT=
CV_PARSER_AI_APP_NAME=Parvagas CV Parser
CV_PARSER_AI_SITE_URL=http://localhost:3000
# Azure OpenAI only
CV_PARSER_AI_AZURE_API_VERSION=2024-10-21

# CV parsing queue guardrails
CV_PARSE_MAX_UPLOAD_MB=5
CV_PARSE_MAX_JOBS_PER_USER_PER_DAY=10
CV_PARSE_TASK_SOFT_TIMEOUT_SECONDS=90
CV_PARSE_TASK_TIMEOUT_SECONDS=120

# CORS
CORS_ORIGIN=http://localhost:3000

# Admin
ADMIN_SIGNUP_KEY=change_me_in_production
SUPER_ADMIN_EMAIL=admin@autisync.com
SUPER_ADMIN_FULL_NAME=AutiSync Super Admin
MODERATOR_EMAIL=
MODERATOR_FULL_NAME=AutiSync Moderator
MODERATOR_SIGNUP_KEY=

# --- reCAPTCHA Enterprise (anti-abuse on login/register/apply) ---
# Leave CAPTCHA_REQUIRED=false (or RECAPTCHA_API_KEY empty) to disable.
CAPTCHA_PROVIDER=recaptcha_enterprise
CAPTCHA_REQUIRED=false
RECAPTCHA_PROJECT_ID=parvagas
RECAPTCHA_API_KEY=
RECAPTCHA_SITE_KEY=6Lf4CistAAAAAIq1r40uoJLlTspXn_05-0pz9zJc
RECAPTCHA_SCORE_THRESHOLD=0.5

# Google Sign-In (OAuth client ID for ID-token verification on /auth/google)
GOOGLE_CLIENT_ID=

# --- Job aggregation (scraping) ---
# JSON array of sources; empty = scraping disabled. Types: json | rss.
# e.g. [{"type":"json","name":"BoardX","url":"https://api.boardx.com/jobs","category":"Tech"}]
SCRAPER_SOURCES=
SCRAPER_USER_AGENT=Parvagas-Bot/1.0 (+https://parvagas.pt/robots.txt)
SCRAPER_MAX_PER_SOURCE=50
# Optional: override admin alert recipients (comma-separated). Defaults to all admins.
ADMIN_ALERT_EMAILS=

# --- Email delivery ---
# Provider: smtp (default) | resend. Resend gives far better Gmail deliverability
# than a shared SMTP IP. Set EMAIL_PROVIDER=resend + RESEND_API_KEY (verify the
# sending domain in Resend first). SMTP_FROM is reused as the From address.
EMAIL_PROVIDER=smtp
RESEND_API_KEY=

# --- SMS / WhatsApp ---
# SMS_PROVIDER: log (default) | twilio | africastalking
SMS_PROVIDER=log
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# Africa's Talking (strong AO coverage)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# WHATSAPP_PROVIDER: log (default) | twilio | meta_cloud
WHATSAPP_PROVIDER=log
TWILIO_WHATSAPP_FROM=

# --- Cloud storage for CVs (STORAGE_PROVIDER: local | supabase) ---
STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=cvs
