# Example environment file for backend-python
# Copy to .env and update values

APP_ENV=development
PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://parvagas_user:change_me@postgres:5432/parvagas

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Auth provider
# local: validates tokens using JWT_SECRET/JWT_ALGORITHM
# auth0: validates bearer tokens against Auth0 JWKS
AUTH_PROVIDER=local
AUTH0_DOMAIN=dev-l6ezvm4bxffm0h0w.eu.auth0.com
AUTH0_AUDIENCE=https://dev-l6ezvm4bxffm0h0w.eu.auth0.com/api/v2/
AUTH0_ISSUER=https://dev-l6ezvm4bxffm0h0w.eu.auth0.com/
AUTH0_ALGORITHMS=RS256

# URLs
# FRONTEND_URL: Set this to where your frontend is deployed
#   - Local: http://localhost:3000
#   - Dev Vercel: https://dev-parvagas.vercel.app
#   - Prod Vercel: https://parvagas.vercel.app
#   - Comma-separated for multiple origins: https://parvagas.vercel.app,https://parvagas.pt
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# CORS_ORIGIN: Additional origins allowed to access this API (comma-separated)
#   Falls back to FRONTEND_URL if not set
#   Example: https://parvagas.vercel.app,https://parvagas.pt
CORS_ORIGIN=

# Traefik Docker-label routing (docker-compose.prod.yml)
# These override the default Host() rules in the labels.
API_HOST=api.parvagas.pt
STORAGE_HOST=storage.parvagas.pt
TRAEFIK_NETWORK=proxy

# SMTP
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-password
SMTP_FROM=Parvagas <noreply@example.com>

# File upload
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# MinIO / object storage
USE_MINIO_STORAGE=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=parvagas
MINIO_REGION=us-east-1
MINIO_URL=

# Optional AI-assisted CV parsing
# Providers: openai, openrouter, azure
CV_PARSER_AI_ENABLED=false
CV_PARSER_AI_PROVIDER=openai
CV_PARSER_AI_BASE_URL=https://api.openai.com/v1
CV_PARSER_AI_API_KEY=
CV_PARSER_AI_MODEL=gpt-4.1-mini
CV_PARSER_AI_TIMEOUT_SECONDS=30
CV_PARSER_AI_ORGANIZATION=
CV_PARSER_AI_PROJECT=
CV_PARSER_AI_APP_NAME=Parvagas CV Parser
CV_PARSER_AI_SITE_URL=http://localhost:3000
# Azure OpenAI only
CV_PARSER_AI_AZURE_API_VERSION=2024-10-21

# --- Shared LLM service (app.services.llm_service) ---
# Powers the optional Llama-backed features below (auto-apply scoring, CV
# keyword injection, candidate premium tools). Defaults to the self-hosted
# Ollama container already in docker-compose.yml — NOTE: pull the model
# yourself first, `OLLAMA_MODELS` in docker-compose.yml only sets the
# storage directory, it does NOT auto-download models:
#   docker exec <ollama-container> ollama pull llama3.2:3b
# Point at OpenAI/Azure/OpenRouter instead by overriding these (same
# provider pattern as CV_PARSER_AI_* above).
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=20

# Per-feature Llama flags — all default OFF (ship dark). Each feature works
# fine with its flag off (falls back to the non-LLM behavior); flip only
# after LLM_ENABLED is confirmed working end-to-end in staging.
AUTO_APPLY_LLM_SCORING_ENABLED=false
CV_EXPORT_LLM_INJECTION_ENABLED=false

# Candidate premium AI tools (interview prep, cover letter, company
# snapshot). While false, EVERY candidate has free access regardless of
# CandidateCVSubscription rows — no pricing has been decided yet. Flip to
# true once a real plan exists; gates on a paid (pro/premium) tier of the
# same subscription table the CV builder itself already uses.
CANDIDATE_PREMIUM_ENABLED=false

# WeasyPrint HTML/CSS-driven resume rendering (Phase B). While false,
# /resumes/{id}/export and /resumes/{id}/preview.html use the Phase A
# reportlab path — requires the Dockerfile's Alpine pango/fontconfig
# packages to be present at runtime to actually take effect.
RESUME_WEASYPRINT_ENABLED=false

# Optional AI-assisted resume scoring and rewrite
RESUME_AI_ENABLED=false
RESUME_AI_PROVIDER=openai
RESUME_AI_BASE_URL=https://api.openai.com/v1
RESUME_AI_API_KEY=
RESUME_AI_MODEL=gpt-4.1-mini
RESUME_AI_TIMEOUT_SECONDS=30
RESUME_AI_ORGANIZATION=
RESUME_AI_PROJECT=
RESUME_AI_APP_NAME=Parvagas Resume AI
RESUME_AI_SITE_URL=http://localhost:3000
# Azure OpenAI only
RESUME_AI_AZURE_API_VERSION=2024-10-21

# CV Builder (Reactive Resume self-hosted)
RESUME_BUILDER_URL=http://localhost:3050
RESUME_BUILDER_SECRET=
RESUME_BUILDER_REFRESH_SECRET=
# SSO bridge — Parvagas acts as an OIDC provider so a logged-in candidate
# lands in the CV builder already authenticated (app.api.v1.resume_sso).
# RESUME_SSO_REDIRECT_URI must exactly match the CV builder's OIDC callback
# URL (its own OAUTH_* config points back at this backend's /oauth/* routes).
RESUME_SSO_CLIENT_ID=reactive-resume
RESUME_SSO_REDIRECT_URI=

# Ollama — free-tier local AI (no subscription required)
# The backend routes CV AI requests to Ollama for free/unsubscribed users
# and to the cloud provider (RESUME_AI_*) for paid subscribers.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FREE_TIER_ENABLED=true
OLLAMA_TIMEOUT_SECONDS=60

# Deploy automation (admin deploy panel)
# Option A — Portainer stack webhook (paste from Portainer → Stack → Webhooks):
DEPLOY_WEBHOOK_URL=
# Option B — git push from the container (enable for simple VPS setups):
DEPLOY_GIT_PUSH=false

# CV parsing queue guardrails
CV_PARSE_MAX_UPLOAD_MB=5
CV_PARSE_MAX_JOBS_PER_USER_PER_DAY=10
CV_PARSE_TASK_SOFT_TIMEOUT_SECONDS=90
CV_PARSE_TASK_TIMEOUT_SECONDS=120

# CORS
CORS_ORIGIN=http://localhost:3000

# Admin
ADMIN_SIGNUP_KEY=change_me_in_production
SUPER_ADMIN_EMAIL=admin@autisync.com
SUPER_ADMIN_FULL_NAME=AutiSync Super Admin
MODERATOR_EMAIL=
MODERATOR_FULL_NAME=AutiSync Moderator
MODERATOR_SIGNUP_KEY=

# --- reCAPTCHA Enterprise (anti-abuse on login/register/apply) ---
# Leave CAPTCHA_REQUIRED=false (or RECAPTCHA_API_KEY empty) to disable.
CAPTCHA_PROVIDER=recaptcha_enterprise
CAPTCHA_REQUIRED=false
RECAPTCHA_PROJECT_ID=parvagas
RECAPTCHA_API_KEY=
RECAPTCHA_SITE_KEY=6LfLODItAAAAABwHKetsgIlJJLM7t45ZpoHmYidQ
RECAPTCHA_SCORE_THRESHOLD=0.5

# Google Sign-In (OAuth client ID for ID-token verification on /auth/google)
GOOGLE_CLIENT_ID=

# --- Job aggregation (scraping) ---
# JSON array of sources; empty = scraping disabled.
# Types: json | rss | greenhouse | lever | careerjet — see the module
# docstring in app/services/scraper_service.py for what each one actually
# covers in the Angola market (Greenhouse/Lever = multinational employers
# who hire in Angola; Careerjet = the one adapter verified to serve the
# Angola market specifically, careerjet.co.ao — READ its docstring before
# enabling, it needs its own affid and has an important caveat about
# republishing terms).
# e.g. [{"type":"json","name":"BoardX","url":"https://api.boardx.com/jobs","category":"Tech"},
#       {"type":"greenhouse","name":"Acme","url":"acme"},
#       {"type":"careerjet","name":"Careerjet Angola","url":"<your affid>","category":"Tecnologia"}]
SCRAPER_SOURCES=
SCRAPER_USER_AGENT=Parvagas-Bot/1.0 (+https://parvagas.pt/robots.txt)
SCRAPER_MAX_PER_SOURCE=50
# Optional: override admin alert recipients (comma-separated). Defaults to all admins.
ADMIN_ALERT_EMAILS=

# --- Email delivery ---
# Provider: smtp (default) | resend. Resend gives far better Gmail deliverability
# than a shared SMTP IP. Set EMAIL_PROVIDER=resend + RESEND_API_KEY (verify the
# sending domain in Resend first). SMTP_FROM is reused as the From address.
EMAIL_PROVIDER=smtp
RESEND_API_KEY=

# --- SMS / WhatsApp --- (ARCHIVED / deferred — gateways no-op until reprioritised)
# Implementation is preserved in git history (commit 308dd26).

# --- Cloud storage for CVs ---
# STORAGE_PROVIDER: local (dev) | supabase (TEMP infra, active now) | server (self-hosted S3/MinIO, FINAL stage)
STORAGE_PROVIDER=local
# Supabase (temporary)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=cvs
# Self-hosted object store on your own server (enable at launch; requires boto3)
S3_ENDPOINT_URL=
S3_BUCKET=cvs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
