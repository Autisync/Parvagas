# ─────────────────────────────────────────────────────────────────────────────
# Parvagas production env — paste these (with REAL values) into Portainer's
# stack "Environment variables" box when deploying docker-compose.prod.yml.
# DO NOT commit a filled-in copy. These mirror your local .env.docker values.
# ─────────────────────────────────────────────────────────────────────────────

# Mark the environment as production (enables the secure-config guard, DEBUG off)
APP_ENV=production

# Supabase Postgres — Session pooler (IPv4), region eu-west-1. From your local
# .env.docker DATABASE_URL (postgresql+psycopg://postgres.<ref>:<pw>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres)
DATABASE_URL=

# Auth / admin
JWT_SECRET=
ADMIN_SIGNUP_KEY=
SUPER_ADMIN_EMAIL=admin@autisync.com
GOOGLE_CLIENT_ID=

# Public domains — MUST match your live sites
FRONTEND_URL=https://parvagas.pt
CORS_ORIGIN=https://parvagas.pt
BACKEND_URL=https://api.parvagas.pt

# Storage — Supabase
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://mhxykmgubdfbjbxqqgzb.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=cvs

# Observability — Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Captcha — reCAPTCHA Enterprise (score-based key)
CAPTCHA_PROVIDER=recaptcha_enterprise
CAPTCHA_REQUIRED=true
RECAPTCHA_API_KEY=
RECAPTCHA_PROJECT_ID=parvagas
RECAPTCHA_SITE_KEY=6LfJUDAtAAAAAG9UPxxPtGoaUNCrnYtyZSnor3fB
RECAPTCHA_SCORE_THRESHOLD=0.5

# Email (transactional)
EMAIL_PROVIDER=smtp
EMAIL_REQUIRED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Resume parsing (optional)
RESUME_PARSER_PROVIDER=
SKIMA_API_KEY=

# Uploads
MAX_UPLOAD_MB=10

# ─── Traefik (file provider) ─────────────────────────────────────────────────
# Only the shared network name is used by compose. The actual route + TLS live in
# deploy/traefik/dynamic/parvagas.yml (copied to /home/autisync/infra/traefik/dynamic/).
TRAEFIK_NETWORK=proxy
