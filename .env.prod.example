# ─────────────────────────────────────────────────────────────────────────────
# Parvagas production env (FULL self-host) — paste into Portainer's stack
# "Environment variables" box with REAL values when deploying docker-compose.prod.yml.
# DO NOT commit a filled-in copy.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production

# ─── Database (self-hosted Postgres) ─────────────────────────────────────────
# DATABASE_URL is built automatically from these three by the compose file.
# Set a strong POSTGRES_PASSWORD (no inline comments — the whole value after = is used).
POSTGRES_DB=parvagas
POSTGRES_USER=parvagas
POSTGRES_PASSWORD=

# ─── Auth / admin ────────────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_SIGNUP_KEY=
SUPER_ADMIN_EMAIL=admin@autisync.com
GOOGLE_CLIENT_ID=

# ─── Public domains ──────────────────────────────────────────────────────────
FRONTEND_URL=https://parvagas.pt
CORS_ORIGIN=https://parvagas.pt
BACKEND_URL=https://api.parvagas.pt

# ─── Storage (self-hosted MinIO) ─────────────────────────────────────────────
# MINIO_ROOT_USER/PASSWORD are the MinIO admin AND the S3 access/secret keys.
# MINIO_ROOT_USER/PASSWORD = MinIO admin AND the S3 access/secret keys. No inline comments.
MINIO_ROOT_USER=parvagas-minio
MINIO_ROOT_PASSWORD=
S3_ENDPOINT_URL=https://storage.parvagas.pt
S3_BUCKET=cvs
S3_REGION=us-east-1

# ─── Observability — Sentry ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Captcha — reCAPTCHA Enterprise (score-based) ────────────────────────────
CAPTCHA_PROVIDER=recaptcha_enterprise
CAPTCHA_REQUIRED=true
RECAPTCHA_API_KEY=
RECAPTCHA_PROJECT_ID=parvagas
# MUST match the frontend NEXT_PUBLIC_RECAPTCHA_SITE_KEY exactly — the backend
# verifies the browser token against THIS key. A mismatch => tokenProperties.valid
# is false => "Verificação anti-robô falhou" on every login.
RECAPTCHA_SITE_KEY=6Lf4CistAAAAAIq1r40uoJLlTspXn_05-0pz9zJc
RECAPTCHA_SCORE_THRESHOLD=0.5
# Escape hatch: if Google Cloud config is still being set up and captcha keeps
# failing, set this to true to LOG the failure but ALLOW the request through.
# Keep false in steady state. Default false (fail closed).
CAPTCHA_FAIL_OPEN=false

# ─── Email (transactional) ───────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
EMAIL_REQUIRED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ─── Resume parsing (optional) ───────────────────────────────────────────────
RESUME_PARSER_PROVIDER=
SKIMA_API_KEY=

# ─── Uploads / backups ───────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7

# ─── Traefik (file provider) ─────────────────────────────────────────────────
TRAEFIK_NETWORK=proxy
