# Parvagas production-only environment template
# Fill all values before deployment.

NODE_ENV=production
PORT=3001

# Core
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=parvagas-private
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
ADMIN_SIGNUP_KEY=REPLACE_WITH_INVITE_KEY_FOR_ADMIN_SIGNUPS
AUTH_MAX_FAILED_LOGINS=8
AUTH_LOCK_MINUTES=15
AUTH_SESSION_IDLE_TIMEOUT_MS=1800000
AUTH_SESSION_TOUCH_INTERVAL_MS=60000
TEMP_PASSWORD_TTL_MINUTES=60
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_MAX=15
RATE_LIMIT_APPLY_MAX=30
RATE_LIMIT_PUBLIC_READ_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_READ_MAX=900000
RATE_LIMIT_GENERAL_READ_MAX=600
RATE_LIMIT_WRITE_MAX=120
RATE_LIMIT_INTERNAL_MESSAGE_MAX=10

# Frontend runtime/public values
NEXT_PUBLIC_SITE_URL=https://parvagas.pt
NEXT_PUBLIC_API_URL=https://api.parvagas.pt
NEXT_PUBLIC_RESUME_BUILDER_URL=https://cv.parvagas.pt
NEXT_PUBLIC_CV_BUILDER_URL=https://cv.parvagas.pt
NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MS=1800000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# CORS
CORS_ORIGIN=https://parvagas.pt

# Storage
STORAGE_PROVIDER=supabase

# AI
AI_PROVIDER=
AI_API_KEY=

# CV Resume Parser
# Options: skima (default), apyhub, manual
RESUME_PARSER_PROVIDER=skima
SKIMA_API_KEY=<your skima key>
APYHUB_API_KEY=<your apyhub key>

# Email
EMAIL_HOST=mail.ehdesigntech.co.uk
EMAIL_PORT=587
EMAIL_USER=parvagas@heliotheanalyst.co.uk
EMAIL_PASS=Parvagas@2026
EMAIL_FROM=parvagas@heliotheanalyst.co.uk
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true

# Search
# Missing MEILISEARCH_HOST disables indexing/search connectivity.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meili_api_key

# Observability
# Missing SENTRY_DSN disables error tracking event delivery.
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# Load gate tuning for CI/staging go-no-go checks
LOAD_BASE_URL=https://api.parvagas.pt
STAGING_LOAD_BASE_URL=https://staging-api.parvagas.pt
LOAD_DURATION_SECONDS=20
LOAD_PIPELINING=1
LOAD_HEALTH_CONNECTIONS=800
LOAD_PUBLIC_CONNECTIONS=800
LOAD_HEALTH_CONNECTION_RATE=3
LOAD_PUBLIC_CONNECTION_RATE=1
LOAD_HEALTH_MAX_P95_MS=350
LOAD_HEALTH_MAX_P99_MS=900
LOAD_HEALTH_MAX_ERROR_RATE=0.02
LOAD_PUBLIC_MAX_P95_MS=450
LOAD_PUBLIC_MAX_P99_MS=1200
LOAD_PUBLIC_MAX_ERROR_RATE=0.03
