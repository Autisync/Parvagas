# Shared defaults (non-secret)
# Portainer does not reliably support nested variable expansion.
# CV_BUILDER_DATABASE_URL must be fully expanded and password URL-encoded.

# PostgreSQL
POSTGRES_USER=parvagas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=parvagas_local
CV_BUILDER_DB=parvagas_cv_builder_local
DATABASE_URL=postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas_local
CV_BUILDER_DATABASE_URL=postgresql://parvagas:CHANGE_ME@postgres:5432/parvagas_cv_builder_local

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CV_BUILDER_S3_BUCKET=reactive-resume-local
S3_BUCKET=cvs-local
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000

# CV Builder
RESUME_BUILDER_SECRET=CHANGE_ME
CV_BUILDER_ENCRYPTION_SECRET=CHANGE_ME_MIN_32_CHARS
CV_BUILDER_DISABLE_SIGNUPS=false
CV_BUILDER_DISABLE_EMAIL_AUTH=false
OAUTH_PROVIDER_NAME=Parvagas
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_DISCOVERY_URL=

# SMTP
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dev@parvagas.pt
SMTP_SECURE=false

# Backend
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_SIGNUP_KEY=dev-admin-key
MODERATOR_SIGNUP_KEY=dev-mod-key
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Traefik
TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
APP_HOST=parvagas.pt
API_HOST=api.parvagas.pt
CV_HOST=cv.parvagas.pt
STORAGE_HOST=storage.parvagas.pt

# Images (Portainer)
FRONTEND_IMAGE=ghcr.io/heliotheanalyst/parvagas-frontend:dev
BACKEND_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:dev
WORKER_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:dev
CV_BUILDER_IMAGE=ghcr.io/heliotheanalyst/parvagas-cv-builder:dev
CV_BUILDER_MIGRATE_IMAGE=ghcr.io/heliotheanalyst/parvagas-cv-builder-migrate:dev
