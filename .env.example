SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=parvagas-private
JWT_SECRET=change-me-to-something-long-and-random
PORT=6001
NODE_ENV=development
AUTH_MAX_FAILED_LOGINS=8
AUTH_LOCK_MINUTES=15
TEMP_PASSWORD_TTL_MINUTES=60
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_MAX=15
RATE_LIMIT_APPLY_MAX=30
RATE_LIMIT_PUBLIC_READ_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_READ_MAX=900000
RATE_LIMIT_GENERAL_READ_MAX=600
RATE_LIMIT_WRITE_MAX=120
RATE_LIMIT_INTERNAL_MESSAGE_MAX=10

# Load gate defaults (used by npm run test:load:gate)
LOAD_BASE_URL=http://localhost:6001
LOAD_DURATION_SECONDS=20
LOAD_PIPELINING=1
LOAD_HEALTH_CONNECTIONS=800
LOAD_PUBLIC_CONNECTIONS=800
LOAD_HEALTH_CONNECTION_RATE=3
LOAD_PUBLIC_CONNECTION_RATE=1
LOAD_HEALTH_MAX_P95_MS=350
LOAD_HEALTH_MAX_P99_MS=900
LOAD_HEALTH_MAX_ERROR_RATE=0.02
LOAD_PUBLIC_MAX_P95_MS=450
LOAD_PUBLIC_MAX_P99_MS=1200
LOAD_PUBLIC_MAX_ERROR_RATE=0.03

# Frontend
NEXT_PUBLIC_SITE_URL=https://parvagas.pt
NEXT_PUBLIC_API_URL=http://localhost:8000
AUTH_CALLBACK_URL=https://parvagas.pt/auth/callback

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,https://parvagas.pt

STORAGE_PROVIDER=local
# Set to 'supabase' in production:
# STORAGE_PROVIDER=supabase

AI_PROVIDER=fallback
AI_API_KEY=

# CV Resume Parser
# Options: skima (default, free tier available), apyhub (token-based), manual (local, no API key)
# Switch providers by changing this value — no code changes required.
RESUME_PARSER_PROVIDER=skima
# Get a free key at https://skima.ai
SKIMA_API_KEY=
# Get a key at https://apyhub.com/utility/resume-extractor
APYHUB_API_KEY=

MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@parvagas.local
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true

# Optional: Sentry error tracking
SENTRY_DSN=

# Warnings:
# - Missing MEILISEARCH_HOST means search indexing will not function.
# - Missing SENTRY_DSN means error tracking events are not sent.

# Production launch rule of thumb:
# - STORAGE_PROVIDER=supabase
# - NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_API_URL must be HTTPS URLs
# - CORS_ORIGIN must list only trusted production/staging origins
# - Run `npm run readiness:production` before deploy
