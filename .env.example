SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=parvagas-private
JWT_SECRET=change-me-to-something-long-and-random
PORT=6001
NODE_ENV=development

# Frontend
NEXT_PUBLIC_SITE_URL=https://parvagas.co.ao
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,https://parvagas.co.ao

STORAGE_PROVIDER=local
# Set to 'supabase' in production:
# STORAGE_PROVIDER=supabase

AI_PROVIDER=fallback
AI_API_KEY=

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@parvagas.local
EMAIL_SECURE=false

# Optional: Sentry error tracking
SENTRY_DSN=

# Production launch rule of thumb:
# - STORAGE_PROVIDER=supabase
# - NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_API_URL must be HTTPS URLs
# - CORS_ORIGIN must list only trusted production/staging origins
# - Run `npm run readiness:production` before deploy
