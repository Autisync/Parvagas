COMPOSE_PROJECT_NAME=parvagas-prod
APP_ENV=production

# Fully expanded URLs only (no nested interpolation)
POSTGRES_USER=parvagas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=parvagas
CV_BUILDER_DB=parvagas_cv_builder
DATABASE_URL=postgresql+psycopg://parvagas:CHANGE_ME@postgres:5432/parvagas
CV_BUILDER_DATABASE_URL=postgresql://parvagas:CHANGE_ME@postgres:5432/parvagas_cv_builder

MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
CV_BUILDER_S3_BUCKET=reactive-resume
S3_BUCKET=cvs

JWT_SECRET=CHANGE_ME
ADMIN_SIGNUP_KEY=CHANGE_ME
RESUME_BUILDER_SECRET=CHANGE_ME
CV_BUILDER_ENCRYPTION_SECRET=CHANGE_ME_MIN_32_CHARS
CORS_ORIGIN=https://parvagas.pt,https://api.parvagas.pt,https://cv.parvagas.pt
# Only disable both when OAuth is configured.
CV_BUILDER_DISABLE_SIGNUPS=true
CV_BUILDER_DISABLE_EMAIL_AUTH=true

OAUTH_PROVIDER_NAME=Parvagas
OAUTH_CLIENT_ID=REQUIRED_IF_SIGNUPS_DISABLED
OAUTH_CLIENT_SECRET=REQUIRED_IF_SIGNUPS_DISABLED
OAUTH_DISCOVERY_URL=REQUIRED_IF_SIGNUPS_DISABLED

# Backend Google sign-in (/api/v1/auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CV Builder default AI provider fallback (used when no saved/tested provider exists)
FLAG_ALLOW_UNSAFE_AI_BASE_URL=true
DEFAULT_AI_PROVIDER=ollama
DEFAULT_AI_MODEL=qwen2.5:3b
DEFAULT_AI_BASE_URL=http://ollama:11434
DEFAULT_AI_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=true

TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
API_HOST=api.parvagas.pt
CV_HOST=cv.parvagas.pt
STORAGE_HOST=storage.parvagas.pt

BACKEND_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:prod
WORKER_IMAGE=ghcr.io/heliotheanalyst/parvagas-backend:prod
CV_BUILDER_IMAGE=amruthpillai/reactive-resume:v5.2.3
