# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# Certificates and keys
*.pem
*.key
*.crt
*.p8

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables - PROTECT SECRETS
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
server/.env
server/.env.local
server/.env.*.local
server/.env.production

# But allow example files so developers know what to set
!.env.example
!.env.production.example
!.env.development.example
!.env.local.example
!server/.env.example
!server/.env.production.example

# Uploads - never commit user-generated files
uploads/
server/public/uploads/
server/uploads/
public/uploads/

# vercel
.vercel
.pnpm-store/

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# Docker env (contains secrets)
.env.docker

# Python build artifacts
__pycache__/
*.pyc
.env*
