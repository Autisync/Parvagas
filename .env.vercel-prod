# Vercel Frontend - Production Environment
# These vars are for the Next.js app deployed on Vercel (production)

# Backend API
NEXT_PUBLIC_API_URL=https://api.parvagas.pt

# Parvagas CV Builder
NEXT_PUBLIC_CV_BUILDER_URL=https://cv.parvagas.pt
NEXT_PUBLIC_RESUME_BUILDER_URL=https://cv.parvagas.pt

# Storage (MinIO S3)
NEXT_PUBLIC_STORAGE_URL=https://storage.parvagas.pt
NEXT_PUBLIC_S3_ENDPOINT=https://storage.parvagas.pt

# App Base URLs
NEXT_PUBLIC_SITE_URL=https://parvagas.pt

# Optional compatibility aliases (legacy docs/code paths)
NEXT_PUBLIC_BACKEND_URL=https://api.parvagas.pt
NEXT_PUBLIC_API_BASE_URL=https://api.parvagas.pt
NEXT_PUBLIC_APP_URL=https://parvagas.pt

# For server-side API calls (if needed)
BACKEND_API_SECRET=<from-backend-.env.prod>
