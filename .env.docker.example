# Postgres container settings
POSTGRES_DB=parvagas
POSTGRES_USER=parvagas_user
POSTGRES_PASSWORD=change_this_now

# Backend runtime
DATABASE_URL=postgresql://parvagas_user:change_this_now@postgres:5432/parvagas
NODE_ENV=production
PORT=8000
FRONTEND_URL=https://your-frontend-domain.com
NEXT_PUBLIC_API_URL=https://your-backend-domain.com
NEXT_PUBLIC_ERROR_LOG_ENDPOINT=https://your-backend-domain.com/api/v1/events/client-errors

# Auth/security
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_SIGNUP_KEY=replace_with_admin_signup_key

# SMTP
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=no-reply@your-domain.com

# Optional operational flags
EMAIL_REQUIRED=true
STORAGE_PROVIDER=local

# Data migration
# Source database that holds old data (required for db:copy:old-to-new)
OLD_DATABASE_URL=
# Target database is optional; defaults to local compose postgres container
# NEW_DATABASE_URL=postgresql://parvagas_user:change_this_now@postgres:5432/parvagas
# Optional safety override for source=target restore (default is false)
# ALLOW_IN_PLACE_COPY=true
