# Postgres container settings
POSTGRES_DB=parvagas
POSTGRES_USER=parvagas_user
POSTGRES_PASSWORD=change_this_now

# Backend runtime
DATABASE_URL=postgresql://parvagas_user:change_this_now@postgres:5432/parvagas
NODE_ENV=production
PORT=8000
FRONTEND_URL=https://your-frontend-domain.com
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# Auth/security
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_SIGNUP_KEY=replace_with_admin_signup_key

# SMTP
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=no-reply@your-domain.com

# Optional operational flags
EMAIL_REQUIRED=true
STORAGE_PROVIDER=local

# CV Builder (Reactive Resume)
RESUME_BUILDER_URL=http://localhost:3050
RESUME_BUILDER_SECRET=replace_with_a_long_random_secret_for_cv_builder
CV_BUILDER_ENCRYPTION_SECRET=replace_with_minimum_32_characters_for_agent_encryption
CV_BUILDER_DATABASE_URL=postgresql://parvagas_user:change_this_now@postgres:5432/parvagas_cv_builder
CV_BUILDER_DISABLE_SIGNUPS=false
CV_BUILDER_DISABLE_EMAIL_AUTH=false
CV_BUILDER_DISABLE_IMAGE_PROCESSING=false

# MinIO credentials used by CV Builder S3 integration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_REGION=us-east-1

# CV Builder OAuth (Parvagas as OIDC provider)
PARVAGAS_OAUTH_PROVIDER_NAME=Parvagas
PARVAGAS_OAUTH_CLIENT_ID=
PARVAGAS_OAUTH_CLIENT_SECRET=
PARVAGAS_OAUTH_DISCOVERY_URL=

# CV Builder sync integration
PARVAGAS_RESUME_SYNC_ENABLED=false
PARVAGAS_API_URL=http://backend-python:8000
PARVAGAS_API_KEY=
PARVAGAS_RESUME_SYNC_PATH=/api/v1/integrations/cv-builder/resumes/sync
PARVAGAS_WEBHOOK_SECRET=

# Data migration
# Source database that holds old data (required for db:copy:old-to-new)
OLD_DATABASE_URL=
# Target database is optional; defaults to local compose postgres container
# NEW_DATABASE_URL=postgresql://parvagas_user:change_this_now@postgres:5432/parvagas
# Optional safety override for source=target restore (default is false)
# ALLOW_IN_PLACE_COPY=true
