# Vercel Frontend - Development Environment
# These vars are for the Next.js app deployed on Vercel (dev environment)
# PUBLIC values + placeholders ONLY — real secrets live in the Vercel dashboard, never here.

# Backend API
NEXT_PUBLIC_API_URL=https://dev-api.parvagas.pt
NEXT_PUBLIC_ERROR_LOG_ENDPOINT=https://dev-api.parvagas.pt/api/v1/events/client-errors

# reCAPTCHA (public site key, but still allowlisted per-domain in the
# reCAPTCHA admin console — get the real value from there, don't reuse
# another environment's key). If unset, the app runs with captcha disabled
# instead of silently falling back to a baked-in key (src/app/layout.tsx).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=<from-recaptcha-admin-console>

# CV Builder (Reactive Resume)
NEXT_PUBLIC_CV_BUILDER_URL=https://cv.dev.parvagas.pt
NEXT_PUBLIC_RESUME_BUILDER_URL=https://cv.dev.parvagas.pt

# Storage (MinIO S3)
NEXT_PUBLIC_STORAGE_URL=https://dev-storage.parvagas.pt
NEXT_PUBLIC_S3_ENDPOINT=https://dev-storage.parvagas.pt

# App Base URLs
NEXT_PUBLIC_SITE_URL=https://dev.parvagas.pt

# Optional compatibility aliases (legacy docs/code paths)
NEXT_PUBLIC_BACKEND_URL=https://dev-api.parvagas.pt
NEXT_PUBLIC_API_BASE_URL=https://dev-api.parvagas.pt
NEXT_PUBLIC_APP_URL=https://dev.parvagas.pt

# For server-side API calls (if needed)
BACKEND_API_SECRET=<from-backend-.env.dev>
